{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prophet Platform Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "bargauge", "name": "Bar gauge", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "description": "GitHub API usage, cost per propagation, and budget tracking. ADR-060.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "API Quota Status",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 80},
              {"color": "red", "value": 95}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "GitHub API Quota Used %",
      "type": "gauge",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "prophet_github_api_quota_percent_used",
          "legendFormat": "Quota Used",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 4000},
              {"color": "red", "value": 4750}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "API Calls This Hour",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "prophet_github_api_calls_per_hour",
          "legendFormat": "API Calls/hr",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"},
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "Warning (80%)"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "yellow"}}]
          },
          {
            "matcher": {"id": "byName", "options": "Critical (95%)"},
            "properties": [{"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}}]
          }
        ]
      },
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 1},
      "id": 3,
      "title": "API Calls Per Hour (with quota thresholds)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "prophet_github_api_calls_per_hour",
          "legendFormat": "API Calls/hr",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "vector(4000)",
          "legendFormat": "Warning (80%)",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "vector(4750)",
          "legendFormat": "Critical (95%)",
          "refId": "C"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 101,
      "title": "Cost Per Repository",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 500},
              {"color": "red", "value": 1000}
            ]
          }
        }
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "id": 4,
      "options": {
        "reduceOptions": {"calcs": ["sum"]},
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "title": "API Calls Per Repo (Top 10)",
      "type": "bargauge",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "topk(10, sum by (repo) (increase(prophet_github_api_calls_total[$__range])))",
          "legendFormat": "{{repo}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 5,
      "title": "API Calls Per Repo Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (repo) (rate(prophet_github_api_calls_total[1h]))",
          "legendFormat": "{{repo}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "id": 102,
      "title": "Cost Per Propagation & Efficiency Trend",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}
      },
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 17},
      "id": 6,
      "title": "API Calls Per Propagation (Efficiency)",
      "description": "Lower is better. Target: fewer API calls per successful propagation.",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "rate(prophet_github_api_calls_total[1h]) / rate(prophet_propagation_success_total[1h])",
          "legendFormat": "API Calls/Propagation",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": []
      },
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 17},
      "id": 7,
      "options": {
        "frameIndex": 0,
        "showHeader": true,
        "sortBy": [{"displayName": "API Calls (Sprint)", "desc": true}]
      },
      "title": "Cost Per Sprint By Repo",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (repo) (prophet_github_api_cost_per_sprint)",
          "legendFormat": "{{repo}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {"id": "labelsToFields", "options": {}},
        {"id": "organize", "options": {"renameByName": {"Value": "API Calls (Sprint)", "repo": "Repository"}}}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["prophet-platform", "cost-tracking", "adr-060"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
        "definition": "label_values(prophet_github_api_calls_total, repo)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "repo",
        "options": [],
        "query": {"query": "label_values(prophet_github_api_calls_total, repo)", "refId": "A"},
        "refresh": 2,
        "sort": 1,
        "type": "query",
        "label": "Repository"
      }
    ]
  },
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Prophet Platform — Cost Tracking",
  "uid": "prophet-cost-tracking",
  "version": 1
}
