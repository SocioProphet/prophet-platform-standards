{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prophet Platform Prometheus datasource",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""},
    {"type": "panel", "id": "gauge", "name": "Gauge", "version": ""},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "table", "name": "Table", "version": ""}
  ],
  "description": "Compliance posture: image signing, vulnerability scanning, RBAC, and policy violations. ADR-050, ADR-060.",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 100,
      "title": "Supply Chain Compliance",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 90},
              {"color": "green", "value": 95}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 1},
      "id": 1,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "% Builds with Valid Signatures",
      "description": "Target: ≥95%. Measures SLSA L3 supply chain compliance per ADR-050.",
      "type": "gauge",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(prophet_build_signed_total) / sum(prophet_build_success_total)",
          "legendFormat": "Signed %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green", "value": 100}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 1},
      "id": 2,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "% Images Scanned for Vulnerabilities",
      "description": "Target: 100%.",
      "type": "gauge",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(prophet_image_scanned_total) / sum(prophet_build_success_total)",
          "legendFormat": "Scanned %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 95},
              {"color": "green", "value": 100}
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 12, "y": 1},
      "id": 3,
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "title": "Audit Log Coverage",
      "description": "% of deployments with audit events. Target: 100%.",
      "type": "gauge",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "100 * sum(prophet_audit_events_deploy_total) / sum(prophet_deploy_success_total + prophet_deploy_failure_total)",
          "legendFormat": "Audit Coverage %",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 6, "w": 6, "x": 18, "y": 1},
      "id": 4,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "FIPS Compliance Rate",
      "description": "Target: 100%. 0 = all builds are FIPS compliant.",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(prophet_build_fips_failures_total) or vector(0)",
          "legendFormat": "FIPS Failures",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 7},
      "id": 101,
      "title": "Policy Violations",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8},
      "id": 5,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Failed Kyverno Policies (24h)",
      "description": "Target: 0. Any value > 0 indicates a policy violation.",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(kyverno_policy_results_total{rule_result=\"fail\"}[24h])) or vector(0)",
          "legendFormat": "Policy Failures",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 1}
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8},
      "id": 6,
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background"},
      "title": "Unsigned Image Detections (24h)",
      "type": "stat",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum(increase(kyverno_policy_results_total{policy=\"require-signed-images\", rule_result=\"fail\"}[24h])) or vector(0)",
          "legendFormat": "Unsigned Images",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {"defaults": {"color": {"mode": "palette-classic"}, "unit": "short"}},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "id": 7,
      "title": "Policy Violations Over Time",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (policy) (rate(kyverno_policy_results_total{rule_result=\"fail\"}[1h]))",
          "legendFormat": "{{policy}}",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
      "fieldConfig": {
        "defaults": {"unit": "short"},
        "overrides": [
          {"matcher": {"id": "byName", "options": "Status"}, "properties": [{"id": "custom.width", "value": 80}]},
          {"matcher": {"id": "byName", "options": "Policy"}, "properties": [{"id": "custom.width", "value": 200}]}
        ]
      },
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 16},
      "id": 8,
      "options": {"frameIndex": 0, "showHeader": true},
      "title": "Policy Violation Details",
      "type": "table",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${DS_PROMETHEUS}"},
          "expr": "sum by (policy, rule, namespace) (increase(kyverno_policy_results_total{rule_result=\"fail\"}[24h]))",
          "legendFormat": "{{policy}} / {{rule}} / {{namespace}}",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        {"id": "labelsToFields", "options": {}},
        {"id": "organize", "options": {"renameByName": {"Value": "Violations (24h)", "policy": "Policy", "rule": "Rule", "namespace": "Namespace"}}}
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["prophet-platform", "compliance", "adr-050", "adr-060"],
  "time": {"from": "now-24h", "to": "now"},
  "timepicker": {},
  "timezone": "browser",
  "title": "Prophet Platform — Compliance & Audit",
  "uid": "prophet-compliance",
  "version": 1
}
